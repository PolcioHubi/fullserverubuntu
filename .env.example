# Copy to .env and fill in real values. NEVER commit a real .env.
#
# Environment selector: "production" or "development".
# Production REFUSES to boot without strong, non-default credentials below.
FLASK_ENV=production

# 32+ byte random hex, e.g.  openssl rand -hex 32
SECRET_KEY=

# Admin login. Do NOT use "admin"/"admin" or other obvious defaults —
# production rejects known-weak values at startup.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Redis endpoints (sessions, cache, rate-limit storage).
# Bare-metal/systemd: redis://127.0.0.1:6379
# docker-compose:     redis://redis:6379
SESSION_REDIS_URL=redis://127.0.0.1:6379
CACHE_REDIS_URL=redis://127.0.0.1:6379/0
RATELIMIT_STORAGE_URL=redis://127.0.0.1:6379

# Optional tuning (defaults shown)
# MAX_CONTENT_LENGTH=536870912
# RECOVERY_TOKEN_TTL_HOURS=24
